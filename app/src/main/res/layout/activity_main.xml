<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Decoupled SDK Test Dashboard"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>
    <Button
        android:id="@+id/btn_show_open"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1. Show App Open Ad"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btn_show_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="2. Show BANNER Ad"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btn_show_rewarded"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="3. Show Rewarded Video"
        android:layout_marginBottom="12dp"/>



</LinearLayout>
